# ============================================================
# VARIABLES D'ENVIRONNEMENT — Takeaway De Brazza App
# ============================================================
# IMPORTANT : Copie ce fichier et renomme-le ".env"
# Ne jamais commiter le fichier .env sur GitHub !
# ============================================================

# Supabase — Récupère ces valeurs sur app.supabase.com
# Projet > Settings > API
VITE_SUPABASE_URL=https://ton-projet.supabase.co
VITE_SUPABASE_ANON_KEY=ta-cle-anonyme-supabase

# Numéro WhatsApp du restaurant (format international, sans +)
# Exemple : 242XXXXXXXXX pour un numéro congolais
VITE_WHATSAPP_NUMERO=242XXXXXXXXX

# Nom et adresse du restaurant (affiché dans l'app)
VITE_RESTAURANT_NOM=Takeaway De Brazza
VITE_RESTAURANT_ADRESSE=Brazzaville, Congo
VITE_RESTAURANT_TEL=+242XXXXXXXXX
